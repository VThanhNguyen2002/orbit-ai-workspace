{
  "name": "@synapse/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "lint": "eslint src --max-warnings=0",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "build": "tsc -p tsconfig.json && pnpm run generate-schemas",
    "generate-schemas": "node scripts/export-json-schemas.mjs",
    "check-schemas": "pnpm run build && node scripts/check-json-schemas.mjs"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^4.1.7"
  }
}
